# Copy this file to .env and fill in your values

# Bot token — from discord.com/developers → your app → Bot → Token
DISCORD_TOKEN=your_bot_token_here

# Application ID — from discord.com/developers → your app → General Information → Application ID
DISCORD_CLIENT_ID=your_client_id_here

# Your Discord server ID — right-click server name → Copy Server ID (requires Developer Mode)
# With this set, commands register instantly. Without it, global registration takes up to 1hr.
DISCORD_GUILD_ID=your_server_id_here
